{
    "private": true,
    "name": "sudoku-for-all",
    "main": "expo-router/entry",
    "version": "1.0.0",
    "packageManager": "pnpm@10.12.1",
    "engines": {
        "node": ">=20"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@shopify/react-native-skia"
        ]
    },
    "scripts": {
        "start": "expo start",
        "start:clear": "expo start --clear",
        "stop": "./scripts/stop",
        "prepare": "husky",
        "//version:bump-comment": "This is used to update the user facing version of the app befor creating a new store build. Learn more in the Builds section of our README document.",
        "version:bump": "node ./scripts/version-bump",
        "//build:comment": "Learn more about builds in this project by reading the Builds section of our README document.",
        "eas": "npx eas-cli@latest",
        "prebuild": "npx expo prebuild --clean",
        "android": "expo run:android",
        "ios": "expo run:ios",
        "edit:ios": "xed ios",
        "edit:android": "open -a \"Android Studio\" android",
        "build:with-eas": "npm run eas -- build",
        "build:with-eas:ios": "npm run build:with-eas -- -p ios",
        "build:with-eas:android": "npm run build:with-eas -- -p android",
        "build:store": "npm run build:with-eas -- -e production --no-wait",
        "build:store:ios": "npm run build:with-eas:ios -- -e production --no-wait",
        "build:store:android": "npm run build:with-eas:android -- -e production --no-wait",
        "build:preview": "npm run build:with-eas -- -e preview",
        "build:preview:ios": "npm run build:with-eas:ios -- -e preview",
        "build:preview:android": "npm run build:with-eas:android -- -e preview",
        "build:preview:ios:simulator": "npm run build:with-eas:ios -- -e preview:simulator",
        "build:development": "npm run build:with-eas -- -e development",
        "build:development:ios": "npm run build:with-eas:ios -- -e development",
        "build:development:android": "npm run build:with-eas:android -- -e development",
        "build:development:ios:simulator": "npm run build:with-eas:ios -- -e development:simulator",
        "build:resign:ios": "npm run eas -- build:resign -p ios",
        "submit:all": "npm run eas -- submit",
        "submit:ios": "npm run eas -- submit -p ios",
        "submit:android": "npm run eas -- submit -p android",
        "device:create": "npm run eas -- device:create",
        "device:rename": "npm run eas -- device:rename",
        "doctor": "npx expo-doctor@latest",
        "expo:gen:typings": "npx expo customize tsconfig.json",
        "pretest": "npm run expo:gen:typings",
        "test": "jest --color",
        "test:watch": "npm run test -- --watch",
        "test:ci": "npm run test --runInBand",
        "precompile": "npm run expo:gen:typings",
        "compile": "tsc --noEmit --skipLibCheck",
        "prelint": "npm run expo:gen:typings",
        "lint": "npx expo lint .",
        "lint:fix": "npm run lint -- --fix"
    },
    "dependencies": {
        "@expo/ui": "55.0.1",
        "@expo/vector-icons": "^15.0.3",
        "@legendapp/state": "^3.0.0-beta.32",
        "@react-navigation/bottom-tabs": "^7.4.0",
        "@react-navigation/elements": "^2.6.4",
        "@react-navigation/native": "^7.1.8",
        "@shopify/react-native-skia": "2.4.18",
        "@tanstack/react-pacer": "^0.17.2",
        "array-fns": "^1.0.0",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "expo": "^55.0.5",
        "expo-blur": "~55.0.8",
        "expo-constants": "~55.0.7",
        "expo-crypto": "~55.0.9",
        "expo-dev-client": "~55.0.11",
        "expo-font": "~55.0.4",
        "expo-glass-effect": "~55.0.7",
        "expo-haptics": "~55.0.8",
        "expo-image": "~55.0.6",
        "expo-linking": "~55.0.7",
        "expo-router": "~55.0.4",
        "expo-screen-orientation": "~55.0.8",
        "expo-splash-screen": "~55.0.10",
        "expo-status-bar": "~55.0.4",
        "expo-symbols": "~55.0.5",
        "expo-system-ui": "~55.0.9",
        "expo-web-browser": "~55.0.9",
        "its-fine": "^2.0.0",
        "jotai": "^2.14.0",
        "json-stringify-pretty-compact": "^4.0.0",
        "lucide-react-native": "^0.511.0",
        "pressto": "^0.6.0",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-native": "0.83.2",
        "react-native-auto-size-text": "^1.1.1",
        "react-native-gesture-handler": "~2.30.0",
        "react-native-reanimated": "4.2.1",
        "react-native-responsive-fontsize": "^0.5.1",
        "react-native-safe-area-context": "~5.6.2",
        "react-native-screens": "~4.23.0",
        "react-native-svg": "15.15.3",
        "react-native-web": "^0.21.1",
        "react-native-webview": "13.16.0",
        "react-native-worklets": "0.7.2",
        "react-test-renderer": "19.0.0",
        "shallowequal": "^1.1.0",
        "sudoku-gen": "^1.0.2",
        "tailwind-merge": "^3.4.0",
        "tailwindcss": "^4.1.17",
        "uniwind": "^1.0.1",
        "use-immer": "^0.11.0",
        "zustand": "^5.0.8"
    },
    "devDependencies": {
        "@expo/metro-runtime": "~55.0.6",
        "@testing-library/react-native": "^13.3.3",
        "@types/jest": "29.5.14",
        "@types/react": "~19.2.10",
        "@types/shallowequal": "^1.1.5",
        "eslint": "^9.35.0",
        "eslint-config-expo": "~55.0.0",
        "husky": "^9.1.7",
        "jest": "~29.7.0",
        "jest-expo": "~55.0.9",
        "typescript": "~5.9.2"
    },
    "lint-staged": {
        "**/*.{ts,tsx,js}": [
            "npm run lint:fix"
        ]
    },
    "jest": {
        "preset": "jest-expo",
        "transformIgnorePatterns": [
            "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/react-native|native-base|react-native-svg|immer|use-immer)"
        ]
    }
}